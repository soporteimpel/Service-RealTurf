# Puerto del servidor
PORT=8080

# --- Rollbase (misma API que plugin CF7 / Wompi webhook) ---
ROLLBASE_API_BASE_URL=https://www.impeltechnology.com/rest/api
ROLLBASE_LOGIN_NAME=realturf.geraldine
ROLLBASE_LOGIN_PASSWORD=TU_PASSWORD_ROLLBASE
ROLLBASE_OBJ_NAME=Prospecto3

# --- Facebook Lead Ads (ver INSTRUCCIONES.md) ---
# Lo inventas tú — debe coincidir con el Verify Token del webhook en Meta
FB_VERIFY_TOKEN=TU_TOKEN_SECRETO_WEBHOOK
# App → Configuración → Básica → Secreto de la app
FB_APP_SECRET=TU_APP_SECRET_FACEBOOK
# Token de la PÁGINA (Graph API) con permiso leads_retrieval — obligatorio para leer leads
FB_PAGE_ACCESS_TOKEN=TU_PAGE_ACCESS_TOKEN
# Opcional: ID de la página. Si no se define, se obtiene automáticamente con /me
FB_PAGE_ID=
FB_GRAPH_API_VERSION=v21.0

# Opcional: IDs de formularios Lead Ads separados por coma (si el token no puede listarlos)
FB_FORM_IDS=

# Secreto para endpoint /sync/leads (Cloud Scheduler o sync manual)
SYNC_SECRET=tu_secreto_sync

# Valores fijos enviados a Rollbase
LEAD_DEFAULT_TEMA="FORMS/FBADS"
LEAD_FIXED_PAIS=Colombia
